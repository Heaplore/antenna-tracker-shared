# Force LF line endings for all text files (坑 22 修复)
# 避免 Windows checkout 时把 LF 转 CRLF, 污染 commit + rebase 冲突
* text=auto eol=lf

# Shell scripts always LF (Windows + git-bash run, 不可 CR)
*.sh text eol=lf
*.bash text eol=lf

# Python always LF
*.py text eol=lf

# YAML / JSON / MD always LF
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf

# Binary
*.png binary
*.jpg binary
*.webp binary
*.ico binary
